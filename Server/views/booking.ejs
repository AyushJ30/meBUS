<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>meBus | Manage Bookings</title>
    <style>
        body { margin: 0; display: flex; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f8fafc; }
        .main-content { flex: 1; padding: 40px; margin-left: 250px; min-height: 100vh; overflow-y: auto; }
        .table-container { background: white; padding: 25px; border-radius: 10px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); margin-bottom: 40px; overflow-x: auto; }
        h2 { color: #1e293b; margin-top: 0; margin-bottom: 20px; border-bottom: 2px solid #e2e8f0; padding-bottom: 10px; }
        
        table { width: 100%; border-collapse: collapse; min-width: 800px; }
        th, td { padding: 12px 15px; text-align: left; border-bottom: 1px solid #e2e8f0; font-size: 14px; }
        th { background-color: #f1f5f9; color: #475569; font-weight: 600; }
        tr:hover { background-color: #f8fafc; }
        
        /* Status Badges */
        .status-badge { padding: 4px 10px; border-radius: 12px; font-size: 12px; font-weight: bold; }
        .status-Upcoming { background-color: #dbeafe; color: #1e40af; }
        .status-Completed { background-color: #dcfce3; color: #166534; }
        .status-Cancelled { background-color: #fee2e2; color: #991b1b; }
        
        /* Cancel Button */
        .cancel-btn { padding: 6px 12px; background-color: #ef4444; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 12px; transition: background 0.2s; }
        .cancel-btn:hover { background-color: #dc2626; }
        .disabled-btn { padding: 6px 12px; background-color: #cbd5e1; color: #64748b; border: none; border-radius: 4px; cursor: not-allowed; font-size: 12px; }

        /* Pagination Styles */
        .pagination { display: flex; justify-content: flex-end; align-items: center; margin-top: 20px; gap: 15px; font-size: 14px; }
        .page-info { color: #475569; font-weight: 500; }
        .pagination-controls { display: flex; gap: 8px; }
        .page-link { padding: 6px 12px; background: white; border: 1px solid #cbd5e1; border-radius: 4px; color: #2563eb; font-weight: 500; cursor: pointer; transition: all 0.2s; }
        .page-link:hover:not(.disabled) { background-color: #f1f5f9; }
        .page-link.disabled { color: #94a3b8; border-color: #e2e8f0; cursor: not-allowed; background-color: #f8fafc; }
    </style>
</head>
<body>

    <%- include('partials/sidebar') %>

    <div class="main-content">
        <h1 style="color: #0f172a; margin-bottom: 30px;">Manage Bookings</h1>

        <% 
            const upcomingBookings = [];
            const pastBookings = [];

            if (locals.bookings && bookings.length > 0) {
                bookings.forEach(booking => {
                    if (booking.status === 'Upcoming') {
                        upcomingBookings.push(booking);
                    } else {
                        pastBookings.push(booking);
                    }
                });
            }
        %>

        <div class="table-container">
            <h2>Upcoming Journeys</h2>
            <table>
                <thead>
                    <tr>
                        <th>ID / PNR</th>
                        <th>User ID</th>
                        <th>Route</th>
                        <th>Bus & Time</th>
                        <th>Seats</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="upcoming-body">
                    <% if (upcomingBookings.length > 0) { %>
                        <% upcomingBookings.forEach(booking => { %>
                            <tr class="paginated-row">
                                <td><strong>#<%= booking.id %></strong><br><span style="color: #64748b; font-size: 12px;"><%= booking.pnr %></span></td>
                                <td>User: <%= booking.userId %></td>
                                <td><%= booking.origin %> &rarr; <%= booking.destination %></td>
                                <td><%= booking.operatorName %><br><span style="color: #64748b; font-size: 12px;"><%= booking.date %> at <%= booking.time %></span></td>
                                <td><%= (booking.seats && Array.isArray(booking.seats)) ? booking.seats.join(', ') : (booking.seats || booking.seatNumber || 'N/A') %></td>
                                <td>₹<%= booking.totalAmount %></td>
                                <td><span class="status-badge status-<%= booking.status %>"><%= booking.status %></span></td>
                                <td>
                                    <form style="margin: 0;" onsubmit="handleCancel(event, '/admin/booking/<%= booking.id %>')">
                                        <button type="submit" class="cancel-btn">Cancel</button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="8" style="text-align: center; color: #64748b;">No upcoming bookings found.</td></tr>
                    <% } %>
                </tbody>
            </table>
            <div id="upcoming-pagination" class="pagination"></div>
        </div>

        <div class="table-container">
            <h2>Past & Cancelled Journeys</h2>
            <table>
                <thead>
                    <tr>
                        <th>ID / PNR</th>
                        <th>User ID</th>
                        <th>Route</th>
                        <th>Bus & Time</th>
                        <th>Seats</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="past-body">
                    <% if (pastBookings.length > 0) { %>
                        <% pastBookings.forEach(booking => { %>
                            <tr class="paginated-row">
                                <td><strong>#<%= booking.id %></strong><br><span style="color: #64748b; font-size: 12px;"><%= booking.pnr %></span></td>
                                <td>User: <%= booking.userId %></td>
                                <td><%= booking.origin %> &rarr; <%= booking.destination %></td>
                                <td><%= booking.operatorName %><br><span style="color: #64748b; font-size: 12px;"><%= booking.date %> at <%= booking.time %></span></td>
                                <td><%= (booking.seats && Array.isArray(booking.seats)) ? booking.seats.join(', ') : (booking.seats || booking.seatNumber || 'N/A') %></td>
                                <td>₹<%= booking.totalAmount %></td>
                                <td><span class="status-badge status-<%= booking.status %>"><%= booking.status %></span></td>
                                <td>
                                    <button class="disabled-btn" disabled>Locked</button>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="8" style="text-align: center; color: #64748b;">No past bookings found.</td></tr>
                    <% } %>
                </tbody>
            </table>
            <div id="past-pagination" class="pagination"></div>
        </div>

        <script>
            // --- Pagination Logic ---
            document.addEventListener('DOMContentLoaded', () => {
                // Initialize pagination: (tableBodyId, paginationContainerId, itemsPerPage)
                setupPagination('upcoming-body', 'upcoming-pagination', 5);
                setupPagination('past-body', 'past-pagination', 10);
            });

            window.paginationStates = {};

            function setupPagination(tbodyId, paginationId, rowsPerPage) {
                const tbody = document.getElementById(tbodyId);
                if (!tbody) return;
                
                const rows = Array.from(tbody.querySelectorAll('tr.paginated-row'));
                if (rows.length === 0) return; // Don't paginate if empty

                const totalPages = Math.ceil(rows.length / rowsPerPage);
                const paginationContainer = document.getElementById(paginationId);

                function renderTable(page) {
                    const start = (page - 1) * rowsPerPage;
                    const end = start + rowsPerPage;
                    
                    rows.forEach((row, index) => {
                        row.style.display = (index >= start && index < end) ? '' : 'none';
                    });
                    
                    renderControls(page);
                }

                function renderControls(page) {
                    if (totalPages <= 1) {
                        paginationContainer.innerHTML = ''; // Hide controls if only 1 page
                        return;
                    }

                    paginationContainer.innerHTML = `
                        <span class="page-info">Page ${page} of ${totalPages}</span>
                        <div class="pagination-controls">
                            <button class="page-link ${page === 1 ? 'disabled' : ''}" 
                                    onclick="changePage('${tbodyId}', ${page - 1})"
                                    ${page === 1 ? 'disabled' : ''}>Previous</button>
                            <button class="page-link ${page === totalPages ? 'disabled' : ''}" 
                                    onclick="changePage('${tbodyId}', ${page + 1})"
                                    ${page === totalPages ? 'disabled' : ''}>Next</button>
                        </div>
                    `;
                }

                window.paginationStates[tbodyId] = { page: 1, total: totalPages, render: renderTable };
                renderTable(1);
            }

            function changePage(tbodyId, newPage) {
                const state = window.paginationStates[tbodyId];
                if (newPage >= 1 && newPage <= state.total) {
                    state.page = newPage;
                    state.render(newPage);
                }
            }

            // --- Cancellation Logic ---
            async function handleCancel(event, url) {
                event.preventDefault();

                const confirmCancel = window.confirm("Are you sure you want to cancel this booking? This action cannot be undone.");
                if (!confirmCancel) return;

                const button = event.target.querySelector('button');
                const originalText = button.innerText;
                button.innerText = 'Cancelling...';
                button.disabled = true;

                try {
                    const response = await fetch(url, {
                        method: 'PATCH',
                        headers: { 'Content-Type': 'application/json' }
                    });

                    if (response.ok) {
                        alert('Booking cancelled successfully.');
                        window.location.reload(); 
                    } else {
                        alert('Failed to cancel booking.');
                        button.innerText = originalText;
                        button.disabled = false;
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert('Network error occurred.');
                    button.innerText = originalText;
                    button.disabled = false;
                }
            }
        </script>

    </div>
</body>
</html>