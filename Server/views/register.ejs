<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>meBus | Register</title> <style>
        body { margin: 0; display: flex; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f8fafc; }
        .main-content { flex: 1; padding: 40px; margin-left: 250px; min-height: 100vh; }
        .form-card { background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); max-width: 600px; margin: 0 auto; }
        h2 { color: #1e293b; margin-top: 0; margin-bottom: 24px; text-align: center; }
        .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .form-group { margin-bottom: 15px; }
        .full-width { grid-column: span 2; }
        label { display: block; margin-bottom: 6px; font-weight: 600; color: #475569; }
        input { width: 100%; padding: 10px; border: 1px solid #cbd5e1; border-radius: 6px; box-sizing: border-box; font-size: 14px; }
        button { width: 100%; margin-top: 20px; padding: 12px; background-color: #2563eb; color: white; border: none; border-radius: 6px; font-weight: bold; cursor: pointer; transition: background 0.2s; }
        button:hover { background-color: #1d4ed8; }
    </style>
</head>
<body>

    <%- include('partials/sidebar') %>

    <div class="main-content">
        <div class="form-card">
            <h2>Admin Register</h2> <form action="/admin/register" method="post"> <div class="form-grid">
                    
                    <div class="form-group full-width">
                        <label>Name:</label> <input name="Name" type="text" placeholder="Name" required /> </div>

                    <div class="form-group">
                        <label>Age:</label> <input name="Age" type="number" placeholder="18" required /> </div>

                    <div class="form-group">
                        <label>Gender:</label> <input name="Gender" type="text" placeholder="Male" required /> </div>

                    <div class="form-group full-width">
                        <label>Email:</label> <input name="Email" type="text" placeholder="example@xyz.com" required /> </div>

                    <div class="form-group">
                        <label>Password:</label> <input name="Password" type="password" placeholder="Password" required /> </div>

                    <div class="form-group">
                        <label>Confirm Password:</label> <input name="ConfirmPassword" type="password" placeholder="Re-Enter Password" required /> </div>

                    <div class="form-group full-width">
                        <label>Phone No.:</label> <input name="Phone" type="number" placeholder="931xxxxxxx" required /> </div>

                </div>

                <button type="submit">REGISTER</button> </form>
        </div>
    </div>

</body>
</html>