<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>meBus | Add-Bus</title> 
    <style>
        body { margin: 0; display: flex; font-family: Arial, sans-serif; background-color: #f4f7f6; }
        .main-content { flex: 1; padding: 40px; margin-left: 250px; } /* Adjust margin-left to sidebar width */
        form { background: white; padding: 25px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); max-width: 600px; }
        label { display: block; margin-top: 15px; font-weight: bold; }
        
        /* Form Inputs */
        input[type="text"], input[type="number"], input[type="time"], select { 
            width: 100%; padding: 10px; margin-top: 5px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; 
        }
        
        /* Checkbox Specific Styles */
        input[type="checkbox"] { width: auto; margin: 0 8px 0 0; }
        .checkbox-label { display: flex; align-items: center; margin-top: 0; font-weight: normal; cursor: pointer; }
        
        button { margin-top: 20px; padding: 10px 20px; background-color: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer; }
        button:hover { background-color: #0056b3; }
    </style>
</head>
<body>

    <%- include('partials/sidebar') %>

    <div class="main-content">
        <h2>Add New Bus</h2>
        <form action="/admin/bus-register" method="post"> 
            
            <label>Bus Name</label>
            <input name="Name" type="text" placeholder="Bus Name" required /> 
            
            <label>From (Origin):</label>
            <select name="Origin" required> 
                <option value="">Select an Option</option> 
                <% if (locals.cities) { %> 
                    <% cities.forEach(city => { %> 
                        <option><%= city.name %></option> 
                    <% }) %>
                <% } %>
            </select>

            <label>To (Destination):</label>
            <select name="Destination" required> 
                <option value="">Select an Option</option> 
                <% if (locals.cities) { %> 
                    <% cities.forEach(city => { %> 
                        <option><%= city.name %></option> 
                    <% }) %>
                <% } %>
            </select>

            <div style="display: flex; gap: 20px;">
                <div style="flex: 1;">
                    <label>Fare:</label>
                    <input name="Fare" type="number" placeholder="in Rupees" required /> 
                </div>
                <div style="flex: 1;">
                    <label>Final Price:</label>
                    <input name="Price" type="number" placeholder="in Rupees" required /> 
                </div>
            </div>

            <label>Total Seats:</label>
            <input name="Seats" type="number" placeholder="No. of Seats in Bus" required /> 
            
            <div style="display: flex; gap: 20px;">
                <div style="flex: 1;">
                    <label>Start Time:</label>
                    <input name="Start" type="time" required /> 
                </div>
                <div style="flex: 1;">
                    <label>Duration:</label>
                    <input name="Duration" type="time" required /> 
                </div>
            </div>

            <label style="margin-top: 20px;">Running Days:</label>
            <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-top: 5px; background: #fff; border: 1px solid #ccc; padding: 15px; border-radius: 4px;">
                <label class="checkbox-label"><input type="checkbox" name="Days" value="sun"> Sunday</label>
                <label class="checkbox-label"><input type="checkbox" name="Days" value="mon"> Monday</label>
                <label class="checkbox-label"><input type="checkbox" name="Days" value="tue"> Tuesday</label>
                <label class="checkbox-label"><input type="checkbox" name="Days" value="wed"> Wednesday</label>
                <label class="checkbox-label"><input type="checkbox" name="Days" value="thu"> Thursday</label>
                <label class="checkbox-label"><input type="checkbox" name="Days" value="fri"> Friday</label>
                <label class="checkbox-label"><input type="checkbox" name="Days" value="sat"> Saturday</label>
            </div>

            <button type="submit">Add Bus</button> 
        </form>
    </div>
</body>
</html>